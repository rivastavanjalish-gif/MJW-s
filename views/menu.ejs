<body class="bg-surface font-body text-on-surface">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 rounded-b-[2rem] bg-[#F8F7FB]/80 dark:bg-stone-900/80 backdrop-blur-2xl shadow-[0_10px_30px_rgba(59,30,84,0.04)]">
<div class="flex justify-between items-center px-8 py-6 w-full">
<div class="flex items-center gap-4">
<button onclick="document.getElementById('mobile-sidebar').classList.remove('hidden')" class="text-[#733CC3] dark:text-[#B497E0] hover:scale-105 transition-transform duration-300 active:scale-95">
<span class="material-symbols-outlined" data-icon="menu">menu</span>
</button>
<h1 onclick="window.location.href='/'" class="cursor-pointer text-2xl font-black italic text-[#733CC3] dark:text-[#B497E0] font-headline tracking-tight">MJW'S SHAKE &amp; SPICY</h1>
</div>
<div class="flex items-center gap-6">
<nav class="hidden md:flex gap-8 font-headline font-bold items-center">
<a class="text-[#3B1E54] dark:text-[#F0E8FF] hover:scale-105 transition-all" href="/">Home</a>
<a class="text-[#733CC3] dark:text-[#B497E0] hover:scale-105 transition-all" href="/menu">Menu</a>
<a class="text-[#3B1E54] dark:text-[#F0E8FF] hover:scale-105 transition-all" href="/#about">Our Story</a>
<% if (user) { %>
<a href="/user" class="flex items-center gap-2 bg-primary-container/20 dark:bg-stone-800 px-3 py-1.5 rounded-full hover:scale-105 transition-transform duration-300 active:scale-95 cursor-pointer">
    <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white font-bold"><%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %></div>
    <span class="font-bold text-primary dark:text-primary-fixed truncate max-w-[100px]"><%= user.name || 'Profile' %></span>
</a>
<% } else { %>
<a class="px-6 py-2 bg-gradient-to-br from-primary to-primary-container text-on-primary rounded-full font-bold hover:scale-105 transition-transform duration-300 active:scale-95 shadow-lg" href="/login">Login</a>
<% } %>
</nav>

</div>
</div>
</header>
<main class="pt-32 pb-20">
<!-- Category Jump Links (Horizontal Scroll) -->
<div class="sticky top-24 z-40 bg-surface/90 backdrop-blur-md pb-4">
<div class="max-w-7xl mx-auto px-6">
    <div id="category-nav" class="flex overflow-x-auto gap-4 py-4 hide-scrollbar">
        <a class="category-link whitespace-nowrap px-8 py-3 bg-gradient-to-br from-[#733CC3] to-[#B497E0] text-white rounded-full font-headline font-semibold shadow-lg hover:scale-105 transition-all duration-300" href="#Shakes" data-category="Shakes">Shakes</a>
        <a class="category-link whitespace-nowrap px-8 py-3 bg-white/50 border border-primary/5 text-[#3B1E54] rounded-full font-headline font-semibold hover:bg-white hover:scale-105 transition-all duration-300" href="#Snacks" data-category="Snacks">Snacks</a>
        <a class="category-link whitespace-nowrap px-8 py-3 bg-white/50 border border-primary/5 text-[#3B1E54] rounded-full font-headline font-semibold hover:bg-white hover:scale-105 transition-all duration-300" href="#Sandwiches" data-category="Sandwiches">Sandwiches</a>
        <a class="category-link whitespace-nowrap px-8 py-3 bg-white/50 border border-primary/5 text-[#3B1E54] rounded-full font-headline font-semibold hover:bg-white hover:scale-105 transition-all duration-300" href="#Burgers" data-category="Burgers">Burgers</a>
        <a class="category-link whitespace-nowrap px-8 py-3 bg-white/50 border border-primary/5 text-[#3B1E54] rounded-full font-headline font-semibold hover:bg-white hover:scale-105 transition-all duration-300" href="#Pizza" data-category="Pizza">Pizza</a>
    </div>
</div>
</div>
<div class="max-w-7xl mx-auto px-6 space-y-24">
<!-- Shakes Section -->
<section class="scroll-mt-48" id="Shakes">
<div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
<div>
<span class="text-tertiary font-bold tracking-widest uppercase text-sm block mb-2">Thick &amp; Creamy</span>
<h2 class="text-5xl font-headline font-extrabold text-primary tracking-tight">Our Signature Shakes</h2>
</div>
</div>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
<% shakes.forEach(product => { %>
    <div class="group bg-white p-6 rounded-[2.5rem] hover:shadow-[0_30px_60px_rgba(59,30,84,0.1)] transition-all duration-700 border border-primary/5 flex flex-col">
        <div class="aspect-square mb-6 overflow-hidden rounded-[2rem] bg-surface-container">
            <img src="<%= product.imageUrl || 'https://images.unsplash.com/photo-1572490122747-3968b75cc699?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>" 
                 data-alt="<%= product.name %>"
                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 <%= !product.isAvailable ? 'grayscale opacity-50' : '' %>">
        </div>
        <div class="flex justify-between items-start mb-2 <%= !product.isAvailable ? 'opacity-50' : '' %>">
            <h3 class="font-headline font-bold text-xl text-on-surface"><%= product.name %></h3>
            <span id="price-<%= product._id %>" class="text-primary font-black">₹<%= product.price %></span>
        </div>
        <p class="text-sm text-on-surface-variant mb-4 <%= !product.isAvailable ? 'opacity-50' : '' %>"><%= product.description || 'Velvety smooth, blended with premium fresh ingredients.' %></p>
        
        <% if (product.hasOptions) { %>
        <div class="flex items-center justify-between bg-surface-container-low p-3 rounded-lg mb-6 <%= !product.isAvailable ? 'opacity-50 pointer-events-none' : '' %>">
            <span class="text-xs font-bold text-secondary uppercase tracking-tighter"><%= product.optionDetails.name %></span>
            <label for="<%= product._id %>-toggle" class="flex items-center cursor-pointer select-none">
                <div class="relative">
                    <input type="checkbox" id="<%= product._id %>-toggle" class="sr-only toggle-checkbox" onchange="const p = document.getElementById('price-<%= product._id %>'); p.innerText = this.checked ? '₹<%= product.price + product.optionDetails.priceIncrease %>' : '₹<%= product.price %>';">
                    <div class="toggle-label block bg-[#E2D9F3] w-12 h-6 rounded-full transition-all duration-300"></div>
                    <div class="toggle-dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-all duration-300 border border-outline-variant/20 shadow-sm"></div>
                </div>
                <span class="ml-2 text-[10px] font-bold text-on-surface-variant">+₹<%= product.optionDetails.priceIncrease %></span>
            </label>
        </div>
        <% } %>

        <% if (product.isAvailable) { %>
            <button onclick="addToCart('<%= product._id %>', document.getElementById('<%= product._id %>-toggle') && document.getElementById('<%= product._id %>-toggle').checked ? '<%= product.optionDetails.name %>' : '')" class="w-full mt-auto py-3 rounded-full bg-primary text-white font-bold hover:bg-primary-dim transition-all active:scale-95 shadow-lg shadow-primary/20">Add to Order</button>
        <% } else { %>
            <button class="w-full mt-auto py-3 rounded-full bg-stone-200 text-stone-500 font-bold cursor-not-allowed" disabled>Unavailable</button>
        <% } %>
    </div>
<% }) %>
</div>
</section>
<!-- Snacks (Patties) Section -->
<section class="scroll-mt-48" id="Snacks">
<div class="bg-white rounded-[3rem] p-10 md:p-16 relative overflow-hidden shadow-[0_20px_40px_rgba(59,30,84,0.03)] border border-primary/5">
<div class="relative z-10">
<span class="text-secondary font-bold tracking-widest uppercase text-sm block mb-2">Crispy Delights</span>
<h2 class="text-4xl font-headline font-extrabold text-on-surface mb-10">Savory Patties</h2>
<div class="grid md:grid-cols-2 gap-x-16 gap-y-6">
<% snacks.forEach(product => { %>
<div class="flex justify-between items-center py-4 border-b border-outline-variant/20 group <%= !product.isAvailable ? 'opacity-50' : '' %>">
<div>
<span class="font-bold text-lg block"><%= product.name %></span>
<span class="text-primary font-black">₹<%= product.price %></span>
</div>
<% if (product.isAvailable) { %>
    <button onclick="addToCart('<%= product._id %>', '')" class="px-6 py-2 rounded-full bg-primary text-white text-sm font-bold hover:bg-primary-dim transition-all active:scale-95">Add to Order</button>
<% } else { %>
    <button class="px-6 py-2 rounded-full bg-stone-200 text-stone-500 text-sm font-bold cursor-not-allowed" disabled>Unavailable</button>
<% } %>
</div>
<% }) %>
</div>
</div>
</div>
</section>
<!-- Sandwiches & Burgers Bento -->
