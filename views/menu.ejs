</div>
<div class="space-y-4">
<% sandwiches.forEach(product => { %>
<div class="p-6 bg-white rounded-[2rem] border border-primary/5 flex justify-between items-center hover:shadow-[0_15px_30px_rgba(59,30,84,0.05)] transition-all duration-500 group <%= !product.isAvailable ? 'opacity-50' : '' %>">
<div>
<div class="font-bold text-lg"><%= product.name %></div>
<div class="text-primary font-black text-xl">₹<%= product.price %></div>
</div>
<% if (product.isAvailable) { %>
    <button onclick="addToCart('<%= product._id %>', '')" class="px-6 py-2 rounded-full bg-primary text-white text-sm font-bold hover:bg-primary-dim transition-all active:scale-95">Add to Order</button>
<% } else { %>
    <button class="px-6 py-2 rounded-full bg-stone-200 text-stone-500 text-sm font-bold cursor-not-allowed" disabled>Unavailable</button>
<% } %>
</div>
<% }) %>
</div>
</section>
<!-- Burgers -->
<section class="scroll-mt-48 space-y-8" id="Burgers">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-tertiary" data-icon="dinner_dining">dinner_dining</span>
<h2 class="text-3xl font-headline font-extrabold text-on-surface">Burger Central</h2>
</div>
<div class="space-y-4">
<% burgers.forEach(product => { %>
<div class="p-8 bg-white rounded-[2rem] border border-primary/5 group hover:shadow-[0_20px_40px_rgba(59,30,84,0.08)] transition-all duration-500 <%= !product.isAvailable ? 'opacity-50' : '' %>">
<div class="flex justify-between items-start mb-2">
<div>
<div class="font-bold text-lg"><%= product.name %></div>
<div class="text-primary font-black text-xl">₹<%= product.price %></div>
</div>
<% if (product.isAvailable) { %>
    <button onclick="addToCart('<%= product._id %>', '')" class="px-6 py-2 rounded-full bg-primary text-white text-sm font-bold hover:bg-primary-dim transition-all active:scale-95">Add to Order</button>
<% } else { %>
    <button class="px-6 py-2 rounded-full bg-stone-200 text-stone-500 text-sm font-bold cursor-not-allowed" disabled>Unavailable</button>
<% } %>
</div>
<p class="text-sm text-on-surface-variant max-w-[70%]"><%= product.description || '' %></p>
</div>
<% }) %>
</div>
</section>
</div>
<!-- Pizza Section -->
<section class="relative scroll-mt-48 my-40 overflow-hidden rounded-[5rem] shadow-[0_40px_80px_rgba(59,30,84,0.15)]" id="Pizza">
    <!-- High-End Background Layer -->
    <div class="absolute inset-0 z-0">
        <img class="w-full h-full object-cover brightness-[0.5] saturate-[0.8]" 
             src="https://images.unsplash.com/photo-1593560708920-61dd98c46a4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" 
             alt="Gourmet Wood-Fired Pizza">
        <!-- Premium Overlays -->
        <div class="absolute inset-0 bg-gradient-to-r from-[#3B1E54] via-[#3B1E54]/85 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#3B1E54]/20 via-transparent to-transparent"></div>
    </div>

    <!-- Content Container (Ultra-Glassmorphism) -->
    <div class="relative z-10 grid lg:grid-cols-2 items-center">
        <div class="p-12 lg:p-28 space-y-12 backdrop-blur-xl bg-white/5 border-r border-white/10 h-full flex flex-col justify-center">
            <div>
                <div class="inline-flex items-center gap-3 px-4 py-2 bg-primary/20 backdrop-blur-md rounded-full border border-primary/30 mb-6">
                    <span class="w-2 h-2 rounded-full bg-primary animate-ping"></span>
                    <span class="text-white font-black tracking-[0.2em] uppercase text-[10px]">Artisan Series</span>
                </div>
                <h2 class="text-5xl font-headline font-black text-white mb-6 leading-[0.9] tracking-tighter">Artisan<br><span class="text-primary-fixed">Wood-Fired</span></h2>
                <div class="flex flex-wrap gap-4">
                    <span class="bg-white/10 backdrop-blur-sm border border-white/20 text-white px-4 py-2 rounded-xl text-[10px] font-bold flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-yellow-400"></span> Extra Cheese: ₹30
                    </span>
                    <span class="bg-white/10 backdrop-blur-sm border border-white/20 text-white px-4 py-2 rounded-xl text-[10px] font-bold flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-green-400"></span> Veggies: ₹20
                    </span>
                </div>
            </div>

            <div class="space-y-8">
                <% pizza.forEach(product => { %>
                <div class="flex flex-col group border-b border-white/5 pb-10 last:border-0 <%= !product.isAvailable ? 'opacity-40' : '' %>">
                    <div class="flex justify-between items-center mb-6">
                        <div class="flex flex-col">
                            <span class="text-2xl font-headline text-white group-hover:text-primary-fixed transition-colors"><%= product.name %></span>
                            <span class="font-black text-xl text-primary-fixed mt-1">₹<%= product.price %></span>
                        </div>
                        <div class="bg-white/5 backdrop-blur-2xl p-4 rounded-[2rem] border border-white/10 space-y-4 min-w-[200px] <%= !product.isAvailable ? 'pointer-events-none' : '' %>">
                            <div class="flex items-center justify-between gap-6">
                                <span class="text-[10px] font-black uppercase tracking-widest text-white/60">Extra Cheese</span>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" id="cheese-<%= product._id %>" class="sr-only toggle-checkbox">
                                    <div class="toggle-label block bg-white/10 w-10 h-5 rounded-full transition-all duration-300"></div>
                                    <div class="toggle-dot absolute left-0.5 top-0.5 bg-white w-4 h-4 rounded-full transition-all duration-300 shadow-sm"></div>
                                </label>
                            </div>
                            <div class="flex items-center justify-between gap-6">
                                <span class="text-[10px] font-black uppercase tracking-widest text-white/60">Veggies</span>
                                <label class="relative inline-flex items-center cursor-pointer">
