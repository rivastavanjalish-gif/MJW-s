<script>
async function addToCart(productId, options = '', addons = {}) {
    try {
        const res = await fetch('/api/cart/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId, options, addons })
        });
        const data = await res.json();
        if (data.success) {
            if (window.showToast) {
                window.showToast('Item added to cart!', 'success');
            } else {
                alert('Item added to cart!');
            }
            // Update cart count badge
            const badges = document.querySelectorAll('.cart-count-badge');
            badges.forEach(b => {
                b.innerText = parseInt(b.innerText || '0') + 1;
            });
        } else {
            alert(data.error || 'Login required to add to cart');
            if (data.error === 'Unauthorized') window.location.href = '/login';
        }
    } catch (e) { console.error(e); }
}
</script>
