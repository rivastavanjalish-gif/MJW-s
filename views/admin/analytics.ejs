<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Analytics Dashboard - MJW'S SHAKE & SPICY</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#733CC3",
                        "primary-dim": "#5A28A0",
                        "secondary": "#9D79D3",
                        "on-surface": "#3B1E54",
                        "on-surface-variant": "#6B6B6B",
                        "surface": "#F8F7FB",
                        "surface-container": "#F0E8FF",
                        "surface-container-low": "#F8F7FB",
                        "surface-container-highest": "#B497E0",
                        "surface-container-lowest": "#FFFFFF",
                        "tertiary": "#C48F00",
                        "outline": "#9D79D3",
                    },
                    borderRadius: {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Be Vietnam Pro"]
                    }
                }
            }
        }
    </script>
    <style>
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #733CC344; border-radius: 10px; }
        body { font-family: 'Be Vietnam Pro', sans-serif; }
    </style>
</head>
<body class="bg-surface text-on-surface">
    <%- include('dashboard_sidebar') %>

    <div class="lg:ml-72 min-h-screen">
        <header class="sticky top-0 z-40 bg-surface/80 backdrop-blur-xl px-8 py-6 flex justify-between items-center border-b border-primary/5">
            <div class="flex items-center gap-4">
                <button class="lg:hidden p-2 text-primary" onclick="toggleSidebar()">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <h1 class="text-2xl font-headline font-black text-primary">Analytics</h1>
            </div>
        </header>

        <main class="p-8 space-y-8">
            <!-- Stats Bento Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-primary/5">
                    <p class="text-xs font-bold text-secondary uppercase tracking-widest mb-2">Total Revenue</p>
                    <h3 class="text-4xl font-black text-primary">₹<%= totalRevenue.toLocaleString() %></h3>
                </div>
                <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-primary/5">
                    <p class="text-xs font-bold text-secondary uppercase tracking-widest mb-2">Orders</p>
                    <h3 class="text-4xl font-black text-primary"><%= totalOrders %></h3>
                </div>
                <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-primary/5">
                    <p class="text-xs font-bold text-secondary uppercase tracking-widest mb-2">Avg. Order</p>
                    <h3 class="text-4xl font-black text-primary">₹<%= Math.round(avgOrderValue) %></h3>
                </div>
                <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-primary/5">
                    <p class="text-xs font-bold text-secondary uppercase tracking-widest mb-2">Growth</p>
                    <h3 class="text-4xl font-black text-green-600">+12%</h3>
                </div>
            </div>

            <!-- Revenue Breakdown -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bg-gradient-to-br from-primary to-primary-dim p-8 rounded-[3rem] text-white shadow-xl shadow-primary/20">
                    <h4 class="text-lg font-headline font-bold mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined">account_balance_wallet</span>
                        Online Payments
                    </h4>
                    <div class="grid grid-cols-2 gap-8">
                        <div>
                            <p class="text-xs font-bold text-white/60 uppercase tracking-widest mb-1">Received (Paid)</p>
                            <h3 class="text-3xl font-black">₹<%= metrics.onlinePaid.toLocaleString() %></h3>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-white/60 uppercase tracking-widest mb-1">Pending (Initiated)</p>
                            <h3 class="text-3xl font-black">₹<%= metrics.onlinePending.toLocaleString() %></h3>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-8 rounded-[3rem] border border-primary/5 shadow-sm">
                    <h4 class="text-lg font-headline font-bold mb-6 flex items-center gap-2 text-primary">
                        <span class="material-symbols-outlined">payments</span>
                        COD (Cash)
                    </h4>
                    <div class="grid grid-cols-2 gap-8">
                        <div>
                            <p class="text-xs font-bold text-secondary uppercase tracking-widest mb-1">Received (Delivered)</p>
                            <h3 class="text-3xl font-black text-on-surface">₹<%= metrics.codReceived.toLocaleString() %></h3>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-secondary uppercase tracking-widest mb-1">Pending (In Transit)</p>
                            <h3 class="text-3xl font-black text-on-surface">₹<%= metrics.codPending.toLocaleString() %></h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts Bento Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <!-- Revenue Trend -->
                <div class="lg:col-span-8 bg-white rounded-[3rem] p-8 shadow-sm border border-primary/5">
                    <h3 class="text-xl font-headline font-bold mb-8">Revenue Trend (Last 7 Days)</h3>
                    <div class="h-[400px]">
                        <canvas id="revenueTrendChart"></canvas>
                    </div>
                </div>

                <!-- Category Mix -->
                <div class="lg:col-span-4 bg-white rounded-[3rem] p-8 shadow-sm border border-primary/5 flex flex-col">
                    <h3 class="text-xl font-headline font-bold mb-8 text-center">Category Distribution</h3>
                    <div class="flex-grow flex items-center justify-center">
                        <div class="w-full max-w-[220px]">
                            <canvas id="categoryMixChart"></canvas>
                        </div>
                    </div>
                    <div class="mt-8 space-y-3">
                        <% categoryMix.forEach((cat, index) => { %>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center">
                                <span class="w-3 h-3 rounded-full mr-3" style="background-color: <%= ['#733CC3', '#9D79D3', '#C48F00', '#3B1E54'][index % 4] %>"></span>
                                <span class="text-sm font-medium"><%= cat._id %></span>
                            </div>
                            <span class="font-bold"><%= cat.value %> orders</span>
                        </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Top Sellers -->
                <div class="lg:col-span-12 bg-white rounded-[3rem] p-8 shadow-sm border border-primary/5">
                    <h3 class="text-xl font-headline font-bold mb-8">Top 5 Best Sellers</h3>
                    <div class="h-[300px]">
                        <canvas id="topItemsChart"></canvas>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        const trendData = <%- JSON.stringify(trend) %>;
        const categoryData = <%- JSON.stringify(categoryMix) %>;
        const topItemsData = <%- JSON.stringify(topItems) %>;

        // Revenue Trend Chart
        new Chart(document.getElementById('revenueTrendChart'), {
            type: 'line',
            data: {
                labels: trendData.map(t => t._id),
                datasets: [{
                    label: 'Daily Revenue (₹)',
                    data: trendData.map(t => t.dailyTotal),
                    borderColor: '#733CC3',
                    backgroundColor: 'rgba(115, 60, 195, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#733CC3',
                    pointRadius: 6,
                    borderWidth: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { display: false }, ticks: { font: { family: 'Be Vietnam Pro' } } },
                    x: { grid: { display: false }, ticks: { font: { family: 'Be Vietnam Pro' } } }
                }
            }
        });

        // Category Mix Chart
        new Chart(document.getElementById('categoryMixChart'), {
            type: 'doughnut',
            data: {
                labels: categoryData.map(c => c._id),
                datasets: [{
                    data: categoryData.map(c => c.value),
                    backgroundColor: ['#733CC3', '#9D79D3', '#C48F00', '#3B1E54'],
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: { legend: { display: false } }
            }
        });

        // Top Items Chart
        new Chart(document.getElementById('topItemsChart'), {
            type: 'bar',
            data: {
                labels: topItemsData.map(i => i._id),
                datasets: [{
                    label: 'Units Sold',
                    data: topItemsData.map(i => i.count),
                    backgroundColor: '#B497E0',
                    borderRadius: 12,
                    barThickness: 40
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                indexAxis: 'y',
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { font: { family: 'Be Vietnam Pro' } } },
                    y: { grid: { display: false }, ticks: { font: { family: 'Be Vietnam Pro', weight: 'bold' } } }
                }
            }
        });
    </script>
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/20 backdrop-blur-sm z-40 hidden lg:hidden" onclick="toggleSidebar()"></div>
</body>
</html>