<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>MJW'S SHAKE & SPICY - User Management</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#733CC3",
                        "primary-dim": "#5A28A0",
                        "secondary": "#9D79D3",
                        "on-surface": "#3B1E54",
                        "on-surface-variant": "#6B6B6B",
                        "surface": "#F8F7FB",
                        "surface-container": "#F0E8FF",
                        "surface-container-low": "#F8F7FB",
                        "surface-container-highest": "#B497E0",
                        "surface-container-lowest": "#FFFFFF",
                        "tertiary": "#C48F00",
                        "outline": "#9D79D3",
                    },
                    borderRadius: {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Be Vietnam Pro"]
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-surface text-on-surface">
    <%- include('dashboard_sidebar') %>

    <div class="lg:ml-72 min-h-screen">
        <header class="sticky top-0 z-40 bg-surface/80 backdrop-blur-xl px-8 py-6 flex justify-between items-center border-b border-primary/5">
            <div class="flex items-center gap-4">
                <button class="lg:hidden p-2 text-primary" onclick="toggleSidebar()">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <h1 class="text-2xl font-headline font-black text-primary">User Management</h1>
            </div>
        </header>

        <main class="p-8">
            <div class="bg-white rounded-3xl shadow-sm border border-primary/5 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="bg-surface text-[10px] font-bold uppercase tracking-widest text-secondary">
                                <th class="px-8 py-6">User</th>
                                <th class="px-8 py-6">Email Address</th>
                                <th class="px-8 py-6">Joined Date</th>
                                <th class="px-8 py-6">Status</th>
                                <th class="px-8 py-6 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-primary/5">
                            <% users.forEach(user => { %>
                            <tr class="hover:bg-surface/50 transition-colors group">
                                <td class="px-8 py-6">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold text-lg">
                                            <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="font-bold text-on-surface"><%= user.name || 'Anonymous' %></span>
                                            <span class="text-[10px] font-black text-secondary uppercase tracking-widest">Customer</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-8 py-6 font-medium text-on-surface-variant">
                                    <%= user.email %>
                                </td>
                                <td class="px-8 py-6 text-sm text-on-surface-variant">
                                    <%= new Date(user.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="px-3 py-1 bg-green-50 text-green-600 text-[10px] font-bold rounded-full uppercase tracking-widest">Active</span>
                                </td>
                                <td class="px-8 py-6 text-right flex justify-end gap-2">
                                    <button onclick="deleteUser('<%= user._id %>')" class="w-10 h-10 rounded-full bg-red-50 text-red-500 hover:bg-red-500 hover:text-white transition-all flex items-center justify-center" title="Delete User">
                                        <span class="material-symbols-outlined text-sm">delete</span>
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script>
        async function deleteUser(userId) {
            if (!confirm('Are you sure you want to delete this user? This action cannot be undone.')) return;
            try {
                const res = await fetch('/admin/users/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId })
                });
                if (res.ok) {
                    location.reload();
                } else {
                    alert('Error deleting user');
                }
            } catch (err) { console.error(err); }
        }
    </script>
    </div>

    <div id="sidebar-overlay" class="fixed inset-0 bg-black/20 backdrop-blur-sm z-40 hidden lg:hidden" onclick="toggleSidebar()"></div>
</body>
</html>